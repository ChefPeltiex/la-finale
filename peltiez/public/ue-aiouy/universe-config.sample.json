{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://egor69.ca/schemas/universe-config.sample.json",
  "title": "Egor69 — échantillon de configuration « univers » pour outillage DCC / UE",
  "description": "Fichier d’exemple : décrire scènes et POI pour aligner équipe web et pipeline Unreal. Aucune synchro automatique avec l’éditeur Epic dans ce dépôt.",
  "type": "object",
  "properties": {
    "universe_id": { "type": "string", "example": "mon-univers-parallele-01" },
    "theme": { "type": "string", "enum": ["futuriste", "medieval", "organique", "cosmique", "mixte"] },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "biome": { "type": "string" },
          "points_of_interest": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "kind": { "type": "string", "description": "commerce | formation | quête | hub" },
                "gltf_uri": { "type": "string", "format": "uri" }
              },
              "required": ["id", "kind"]
            }
          }
        },
        "required": ["id", "label"]
      }
    },
    "unreal": {
      "type": "object",
      "properties": {
        "recommended_engine_version": { "type": "string", "example": "5.4" },
        "pixel_streaming": { "type": "boolean", "default": false },
        "notes": { "type": "string" }
      }
    }
  },
  "required": ["universe_id", "scenes"]
}
