{
  "name": "egor69",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.0.0",
  "description": "**Welcome to IGOR**",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node ./server/index.js",
    "ab:server-demo": "node ./server/ab-server.js",
    "dev:stack": "concurrently -k -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:api\"",
    "server": "node ./server/index.js",
    "backend": "node ./server/index.js",
    "build": "vite build",
    "analyze": "vite build --mode production",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -p ./jsconfig.json",
    "preview": "vite preview",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "verify:deep": "npx eslint . && npm run typecheck && npm run build && npm audit --audit-level=moderate && node ./guardian.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "pipeline": "npm run verify",
    "start": "node ./server/index.js",
    "start:prod": "node ./server/index.js",
    "start:server": "node ./server/index.js",
    "docs:dossier-pdf": "node ./scripts/generate-strategy-dossier-pdf.mjs",
    "docs:synthese-complete-pdf": "node ./scripts/generate-circulai-synthese-complete-pdf.mjs",
    "atlas:convert": "node scripts/run-atlas-convert.mjs",
    "purify:caches": "node ./scripts/purge-vite-caches.mjs",
    "purify": "npm run purify:caches && npm ci",
    "purify:dev": "npm run purify && npm run dev",
    "multiverse:guard": "node ./guardian.js",
    "guardian:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/guardian.ps1",
    "guardian:ps:daemon": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/guardian.ps1 -Daemon",
    "repair:npm-ci": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/repair-npm-ci-eperm.ps1",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-universal.ps1",
    "dev:clean:no-dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-universal.ps1 -NoDev"
  },
